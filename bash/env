### Bash History
HISTSIZE=10000
HISTFILESIZE=20000

### Path Settings
# Homebrew (sets HOMEBREW_PREFIX, PATH, etc.)
# Probes user-local prefixes first so this works on machines where Homebrew
# is installed into $HOME (no admin access) rather than /opt/homebrew or /usr/local.
for _brew in \
  "$HOME/homebrew/bin/brew" \
  "$HOME/.homebrew/bin/brew" \
  "$HOME/.linuxbrew/bin/brew" \
  "/opt/homebrew/bin/brew" \
  "/home/linuxbrew/.linuxbrew/bin/brew" \
  "/usr/local/bin/brew"; do
  if [ -x "$_brew" ]; then
    eval "$("$_brew" shellenv)"
    break
  fi
done
unset _brew

PATH="$HOME/bin:$PATH"
PATH="$HOME/.local/bin:$PATH"
PATH="$HOME/.config/emacs/bin:$PATH"
PATH="$HOME/.docker/cli-plugins/:$PATH"

# Activate mise
if command -v mise &>/dev/null; then
  eval "$(mise activate bash)"
fi
export PATH

### Locale
export LANG=en_US.UTF-8

# vcpkg
export VCPKG_ROOT="$HOME/vcpkg"
if [ -n "$HOMEBREW_PREFIX" ] && [ -d "$HOMEBREW_PREFIX/opt/openblas/lib/pkgconfig" ]; then
  export PKG_CONFIG_PATH="$HOMEBREW_PREFIX/opt/openblas/lib/pkgconfig${PKG_CONFIG_PATH:+:$PKG_CONFIG_PATH}"
fi

# Keep Ollama models resident between completions (default is 5m)
export OLLAMA_KEEP_ALIVE=30m
