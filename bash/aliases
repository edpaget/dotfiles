alias ..='cd ..'
alias g='git'
alias senv='source .env'
alias tmux='tmux -2'
alias wm='workmux'
alias dockerip="docker inspect --format '{{ .NetworkSettings.IPAddress}}'"
alias gp='git push'
alias grep='grep --color=auto'
alias fgrep='fgrep --color=auto'
alias egrep='egrep --color=auto'
alias gco='git clone git@github.com:'
alias gsnows='git diff -U0 -w --no-color | git apply --cached --ignore-whitespace --unidiff-zero -'

if [ `uname` == "Linux" ]; then
   alias la='ls -al --color=auto'
   alias ls='ls --color=auto'
   alias grep='grep --color=auto'
   alias fgrep='fgrep --color=auto'
   alias egrep='egrep --color=auto'
fi

if [ `uname` == "Darwin" ]; then
   # Prefer GNU coreutils (gls, ggrep, etc. from `brew install coreutils`/`grep`)
   # but fall back to BSD tools when GNU isn't installed (e.g. minimal/user-only setups).
   if command -v gls &>/dev/null; then
     alias la='gls -al --color=auto'
     alias ls='gls --color=auto'
   else
     alias la='ls -al'
   fi
   if command -v ggrep &>/dev/null; then
     alias grep='ggrep --color=auto'
     alias fgrep='gfgrep --color=auto'
     alias egrep='gegrep --color=auto'
   fi
fi
